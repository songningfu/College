; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="College"
run/main_scene="res://scenes/ui/ui_test_v2.tscn"
config/features=PackedStringArray("4.6")

[autoload]

ThemeColors="*res://scripts/core/theme_colors.gd"
GameManager="*res://scripts/core/game_manager.gd"
AttributeSystem="*res://scripts/core/attribute_system.gd"
RelationshipSystem="*res://scripts/core/relationship_system.gd"
CardSystem="*res://scripts/core/card_system.gd"
EventSystem="*res://scripts/core/event_system.gd"
DayManager="*res://scripts/core/day_manager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
